{
  "name": "@ncc/bank-verification-ui",
  "version": "0.1.0",
  "description": "Bank verification UI and hooks for checkout flows",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./express": {
      "types": "./dist/express-router.d.ts",
      "import": "./dist/express-router.js",
      "require": "./dist/express-router.cjs"
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "VITE_INTEGRATION.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "node scripts/generate-css-string.js && node scripts/generate-bank-logos.js && tsup && cp src/styles/bank-ui.css dist/index.css",
    "dev": "node scripts/dev-server.js",
    "typecheck": "tsc --noEmit",
    "html-to-tsx": "node scripts/html-to-tsx.js",
    "extract-base64-images": "node scripts/extract-base64-images.js",
    "download-uae-bank-logos": "node scripts/download-uae-bank-logos.js"
  },
  "peerDependencies": {
    "express": "^4.0.0",
    "express-ws": "^5.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "express-ws": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "express": "^4.21.0",
    "express-ws": "^5.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "htmltojsx": "^0.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0 || ^6.0.0 || ^7.0.0"
  }
}
